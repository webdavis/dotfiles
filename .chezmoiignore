# Ignore GitHub/repo metadata:
README.md
LICENSE
CLAUDE.md
AGENTS.md
.gitignore
assets/
docs/
private/

# Repo scripts & helpers:
justfile
.envrc
scripts/
test/

# Ignore formatter/linter configs:
.shellcheckrc
.editorconfig # shfmt uses EditorConfig as its rc file (so to speak).
.mdformat.toml

# Git hooks (dev-only):
.githooks/

# Nix flake files:
flake.nix
flake.lock
treefmt.nix

# Failsafe so that stray tmp files in the source tree don't get applied to HOME.
tmp.*
*.rayconfig
*extension-diagnostics*

# macOS Finder turds (e.g. Library/Application Support/.DS_Store).
**/.DS_Store

# Skill repos bring their own .git/ and node_modules/;
# don't track those in this dotfiles repo.
.agents/skills/*/.git
.agents/skills/*/.git/**
.agents/skills/*/node_modules
.agents/skills/*/node_modules/**

# Rust build artifacts for vendored herdr projects (rebuilt in-place at apply; never deploy).
.local/share/herdr/**/target

{{- if eq .chezmoi.os "linux" -}}
.config/yabai
Library
.local/bin/macos-defaults-drift.sh
.local/bin/macos-defaults-apply.sh
.local/bin/macos-defaults-capture.sh
{{- end -}}
