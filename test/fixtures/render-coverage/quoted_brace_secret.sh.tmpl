#!/bin/bash
# Fixture (F5): a keepassxc action whose double-quoted Go string argument
# contains a literal `}`. A naive `[^}]*` action extractor cannot match this
# action (the quoted `}` truncates it), so it sees NO action and classifies the
# template safe -- admitting a secret template to headless rendering. The
# quote-aware extractor must treat a `}` inside a double-quoted Go string as
# non-structural and still see the secret call (verdict: excluded).
set -euo pipefail
token={{ keepassxc "entry}name" }}
echo "$token"
