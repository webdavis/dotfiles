# Ensure Bash secret files can never be committed no matter what.
*bash_secret*

# Ignore macOS Finder metadata.
.DS_Store

# Ignore Ruby project dependencies.
vendor/**
.vendor/**
.ruby-lsp/**

# Ignore Vim/Neovim swap files.
*.sw*

# Raycast exports and diagnostics.
*.rayconfig
*extension-diagnostics*

# Claude Code session data.
.claude/

# Git worktrees (isolated implementation workspaces).
.worktrees/

# Knowledge-graph output regenerated by the user-wide graphify post-commit hook.
# Band-aid: droppable once the managed post-commit dispatcher is applied live —
# .githooks/no-graphify then stops graphify from writing here at all.
graphify-out/
