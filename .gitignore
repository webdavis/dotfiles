# Ensure Bash secret files can never be committed no matter what.
*bash_secret*

# Ignore macOS Finder metadata.
.DS_Store

# Ignore Ruby project dependencies.
vendor/**
.vendor/**
.ruby-lsp/**

# Ignore Vim/Neovim swap files.
*.sw*

# Raycast exports and diagnostics.
*.rayconfig
*extension-diagnostics*

# Claude Code session data.
.claude/

# Git worktrees (isolated implementation workspaces).
.worktrees/

# Agent scratch (superpowers SDD briefs, reports, evidence — never tracked).
.superpowers/

# Knowledge-graph output: graph.json is the committed map (rebuilt after each
# commit by this repo's .githooks/post-commit); everything else in
# graphify-out/ (html, report, cache, dated snapshots) is a regenerable
# artifact and stays untracked.
graphify-out/*
!graphify-out/graph.json

# Rust build artifacts for vendored herdr projects (plugins + binaries, built in-place, never committed).
dot_local/share/herdr/**/target/
