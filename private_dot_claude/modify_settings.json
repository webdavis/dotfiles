{{- /* chezmoi:modify-template */ -}}
{{- /*
  Selective field control for ~/.claude/settings.json.

  Why: Claude Code's /config slash command writes user-toggled settings
  (alwaysThinkingEnabled, useAutoModeDuringPlan, voiceEnabled, etc.) directly
  into ~/.claude/settings.json, which would create drift against any plain
  chezmoi template. There is no user-level ~/.claude/settings.local.json that
  Claude Code reads, so a clean split into local/shared isn't possible at the
  user scope.

  How: this is a chezmoi modify-template (https://www.chezmoi.io/user-guide/
  manage-different-types-of-file/#modify-templates). It receives the current
  ~/.claude/settings.json on .chezmoi.stdin, overlays the stable fields below
  via setValueAtPath, and writes the merged result back. Ergonomic toggles
  (anything not in the stable list) are passed through untouched.

  Promote a /config toggle to "managed" by adding it to one of the
  setValueAtPath calls below.
*/ -}}
{{- /* .chezmoi.stdin is only set when chezmoi runs the modify template
       with a real target file. Use safe access so the template still
       renders cleanly under `chezmoi execute-template` for ad-hoc testing. */ -}}
{{- $stdin := index .chezmoi "stdin" | default "" -}}
{{- $merged := dict -}}
{{- if $stdin -}}
{{-   $merged = fromJson $stdin -}}
{{- end -}}

{{- /* --- stable: scalars and policy --- */ -}}
{{- $merged = setValueAtPath "cleanupPeriodDays" 36525 $merged -}}
{{- $merged = setValueAtPath "autoUpdatesChannel" "stable" $merged -}}
{{- $merged = setValueAtPath "remoteControlAtStartup" true $merged -}}

{{- $permissions := dict
    "allow" (list
      "Read"
      "Grep"
      "Glob"
      "WebFetch"
      "WebSearch"
      "Bash(find *)"
      "Bash(cat *)"
      "Bash(ls *)"
      "Bash(head *)"
      "Bash(tail *)"
      "Bash(wc *)"
      "Bash(grep *)"
      "Bash(tree *)")
    "deny" (list
      "Read(.env)"
      "Read(.env.*)"
      "Read(secrets/**)"
      "Read(credentials.json)"
      "Read(.aws/credentials)"
      "Read(.ssh/id_*)")
    "defaultMode" "bypassPermissions" -}}
{{- $merged = setValueAtPath "permissions" $permissions $merged -}}

{{- /* --- stable: hooks (paths use $home for portability) --- */ -}}
{{- $home := .chezmoi.homeDir -}}
{{- $hooks := dict
    "UserPromptSubmit" (list (dict
      "hooks" (list (dict
        "type" "command"
        "command" (printf "%s/.local/bin/claude-user-prompt-start.sh" $home)))))
    "Stop" (list (dict
      "hooks" (list
        (dict
          "type" "command"
          "command" (printf "%s/.local/bin/claude-stop-pulse.sh" $home))
        (dict
          "type" "command"
          "async" true
          "command" (printf "%s/.local/bin/relay-agent.sh done" $home)))))
    "Notification" (list (dict
      "matcher" "permission_prompt"
      "hooks" (list
        (dict
          "type" "command"
          "command" "alerter --timeout 30 --title 'Claude Code' --message 'Needs attention' --sound default")
        (dict
          "type" "command"
          "async" true
          "command" (printf "%s/.local/bin/relay-agent.sh blocked" $home)))))
    "PostToolUse" (list
      (dict
        "matcher" "AskUserQuestion"
        "hooks" (list (dict
          "type" "command"
          "async" true
          "command" (printf "%s/.local/bin/relay-agent.sh asked" $home))))
      (dict
        "matcher" "ExitPlanMode"
        "hooks" (list (dict
          "type" "command"
          "async" true
          "command" (printf "%s/.local/bin/relay-agent.sh plan-ready" $home)))))
    "PreToolUse" (list (dict
      "matcher" "Bash"
      "hooks" (list (dict
        "type" "command"
        "command" (printf "%s/.local/bin/claude-audit.sh" $home))))) -}}
{{- $merged = setValueAtPath "hooks" $hooks $merged -}}

{{- /* --- stable: statusLine (path uses $home) --- */ -}}
{{- $statusLine := dict
    "type" "command"
    "command" (printf "bash %s/.claude/statusline-command.sh" $home) -}}
{{- $merged = setValueAtPath "statusLine" $statusLine $merged -}}

{{- /* --- stable: plugins enabled by default --- */ -}}
{{- $enabledPlugins := dict
    "superpowers@claude-plugins-official" true
    "document-skills@anthropic-agent-skills" true
    "frontend-design@claude-plugins-official" true
    "playwright@claude-plugins-official" true
    "security-guidance@claude-plugins-official" true
    "swift-lsp@claude-plugins-official" true -}}
{{- $merged = setValueAtPath "enabledPlugins" $enabledPlugins $merged -}}

{{- /* --- stable: skill tiering (on-demand skills load only when the user
       invokes them). Source of truth: the tiers table in
       dot_agents/custom-skill-lock.json — every on-demand skill gets exactly
       one entry here, core skills get none, and test/unit/skills-roster-fanout.sh
       fails the build when the two sets diverge. Per-key setValueAtPath (not
       one whole-dict overwrite) so overrides the user sets for other skills
       via /config pass through untouched. --- */ -}}
{{- $merged = setValueAtPath "skillOverrides.cua-driver" "user-invocable-only" $merged -}}
{{- $merged = setValueAtPath "skillOverrides.elevenlabs" "user-invocable-only" $merged -}}
{{- $merged = setValueAtPath "skillOverrides.embedded-captions" "user-invocable-only" $merged -}}
{{- $merged = setValueAtPath "skillOverrides.faceless-explainer" "user-invocable-only" $merged -}}
{{- $merged = setValueAtPath "skillOverrides.general-video" "user-invocable-only" $merged -}}
{{- $merged = setValueAtPath "skillOverrides.home-assistant" "user-invocable-only" $merged -}}
{{- $merged = setValueAtPath "skillOverrides.home-assistant-best-practices" "user-invocable-only" $merged -}}
{{- $merged = setValueAtPath "skillOverrides.hyperframes" "user-invocable-only" $merged -}}
{{- $merged = setValueAtPath "skillOverrides.hyperframes-animation" "user-invocable-only" $merged -}}
{{- $merged = setValueAtPath "skillOverrides.hyperframes-cli" "user-invocable-only" $merged -}}
{{- $merged = setValueAtPath "skillOverrides.hyperframes-core" "user-invocable-only" $merged -}}
{{- $merged = setValueAtPath "skillOverrides.hyperframes-creative" "user-invocable-only" $merged -}}
{{- $merged = setValueAtPath "skillOverrides.hyperframes-keyframes" "user-invocable-only" $merged -}}
{{- $merged = setValueAtPath "skillOverrides.hyperframes-registry" "user-invocable-only" $merged -}}
{{- $merged = setValueAtPath "skillOverrides.kubernetes-specialist" "user-invocable-only" $merged -}}
{{- $merged = setValueAtPath "skillOverrides.last30days" "user-invocable-only" $merged -}}
{{- $merged = setValueAtPath "skillOverrides.lobster" "user-invocable-only" $merged -}}
{{- $merged = setValueAtPath "skillOverrides.media-use" "user-invocable-only" $merged -}}
{{- $merged = setValueAtPath "skillOverrides.motion-graphics" "user-invocable-only" $merged -}}
{{- $merged = setValueAtPath "skillOverrides.summarize-pro" "user-invocable-only" $merged -}}
{{- $merged = setValueAtPath "skillOverrides.tiktok-crawling" "user-invocable-only" $merged -}}
{{- $merged = setValueAtPath "skillOverrides.video-transcript-downloader" "user-invocable-only" $merged -}}
{{- $merged = setValueAtPath "skillOverrides.website-to-video" "user-invocable-only" $merged -}}

{{ $merged | toPrettyJson }}
