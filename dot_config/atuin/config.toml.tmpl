## Atuin configuration
## Docs: https://docs.atuin.sh/configuration/config/

## Keep non-sync settings at the top level (atuin puts them there).
search_mode = "prefix"
filter_mode = "host"
filter_mode_shell_up_key_binding = "session"
style = "compact"
enter_accept = true
secrets_filter = true

## Custom regex patterns that prevent matching commands from being recorded.
## history_filter is the atuin equivalent of bash's HISTIGNORE.
## Regex lives in KeePassXC — same entry that previously populated HISTIGNORE.
## Ref: https://docs.atuin.sh/configuration/config/#history_filter
history_filter = [
  {{ (keepassxc "Dotfiles (bashrc) :: HISTIGNORE Regex").Password | quote }},
]

[sync]
auto_sync = false
records = true

[ai]
enabled = true

[daemon]
enabled = true
# autostart=false: daemon is managed by ~/Library/LaunchAgents/com.webdavis.atuin-daemon.plist
# (avoids race conditions between LaunchAgent and shell-init autostart).
autostart = false
