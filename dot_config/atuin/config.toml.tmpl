# Atuin: https://atuin.sh/
# Local-only shell history backed by SQLite.

# Disable cloud sync — fully local.
auto_sync = false

# Search settings.
search_mode = "fuzzy"
filter_mode = "global"

# Enter executes directly; Tab to edit before executing.
enter_accept = true

# Auto-filter secrets (AWS keys, GitHub tokens, etc.).
secrets_filter = true
