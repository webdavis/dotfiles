#!/usr/bin/env bash
# Global post-commit dispatcher: runs a repository's own post-commit hook.
# Activated by core.hooksPath in dot_gitconfig.tmpl, so it runs in every repo.
#
# The user-wide hooks dir must stay authoritative so the global
# prepare-commit-msg AI hook runs everywhere. A per-repo `core.hooksPath`
# override (e.g. what `git lfs install` writes) would shadow it. To keep
# post-commit behavior per-repo without that override, each repo opts in by
# tracking an executable `.githooks/post-commit`; this dispatcher runs it.
# (Graphify rebuilds moved from this dispatcher to exactly that per-repo
# mechanism: a repo that wants a knowledge-graph rebuild after each commit
# carries its own `.githooks/post-commit` calling the graphify CLI. Nothing
# global runs graphify anymore.)
#
# Repos without `.githooks/post-commit` get a no-op.

toplevel="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
repo_hook="${toplevel}/.githooks/post-commit"
[[ -x $repo_hook ]] && exec "$repo_hook" "$@"
exit 0
