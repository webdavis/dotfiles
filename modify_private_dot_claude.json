{{- /* chezmoi:modify-template */ -}}
{{- /*
  Selective field control for ~/.claude.json (composio + workspace-mcp).

  Why: `claude mcp add` writes secrets in plaintext to ~/.claude.json.
  Vaulting via KeePassXC keeps secrets out of git and lets them rotate
  upstream (composio dashboard, Google Cloud Console) without re-editing
  the source tree.

  How: chezmoi modify-template. Reads current ~/.claude.json from
  .chezmoi.stdin, overlays the managed mcpServers entries with vaulted
  values, writes the merged result back. All other fields (project
  state, telemetry IDs, additional MCP servers, etc.) pass through.
*/ -}}
{{- $stdin := index .chezmoi "stdin" | default "" -}}
{{- $merged := dict -}}
{{- if $stdin -}}
{{-   $merged = fromJson $stdin -}}
{{- end -}}

{{- /* --- stable: composio MCP entry --- */ -}}
{{- $composio := dict
    "type" "http"
    "url" "https://connect.composio.dev/mcp"
    "headers" (dict
      "x-consumer-api-key" ((keepassxc "Composio :: API Key :: MCP").Password)) -}}
{{- $merged = setValueAtPath "mcpServers.composio" $composio $merged -}}

{{- /* --- stable: workspace-mcp entry (Google Workspace via OAuth) --- */ -}}
{{- $workspaceMcp := dict
    "type" "stdio"
    "command" "uvx"
    "args" (list "workspace-mcp" "--tool-tier" "complete")
    "env" (dict
      "GOOGLE_OAUTH_CLIENT_ID" ((keepassxc "Google Cloud (webdavis.io) :: OAuth :: google-workspace-mcp").UserName)
      "GOOGLE_OAUTH_CLIENT_SECRET" ((keepassxc "Google Cloud (webdavis.io) :: OAuth :: google-workspace-mcp").Password)
      "OAUTHLIB_INSECURE_TRANSPORT" "1") -}}
{{- $merged = setValueAtPath "mcpServers.workspace-mcp" $workspaceMcp $merged -}}

{{ $merged | toPrettyJson }}
