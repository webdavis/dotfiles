<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.webdavis.osquery-report</string>
  <key>ProgramArguments</key>
  <array>
    <string>{{ .chezmoi.homeDir }}/.local/bin/osquery-report.sh</string>
  </array>
  <key>StartInterval</key>
  <integer>21600</integer>
  <key>InitialDelay</key>
  <integer>300</integer>
  <key>StandardOutPath</key>
  <string>{{ .chezmoi.homeDir }}/.local/log/osquery/launchd-report.log</string>
  <key>StandardErrorPath</key>
  <string>{{ .chezmoi.homeDir }}/.local/log/osquery/launchd-report.log</string>
  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
