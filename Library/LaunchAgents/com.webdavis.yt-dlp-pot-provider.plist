<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.webdavis.yt-dlp-pot-provider</string>
  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/deno</string>
    <string>run</string>
    <string>--allow-env</string>
    <string>--allow-net</string>
    <string>--allow-ffi=.</string>
    <string>--allow-read=.</string>
    <string>../src/main.ts</string>
  </array>
  <key>WorkingDirectory</key>
  <string>/Users/stephen/.local/share/yt-dlp/bgutil-ytdlp-pot-provider/server/node_modules</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>ThrottleInterval</key>
  <integer>10</integer>
  <key>StandardOutPath</key>
  <string>/Users/stephen/.local/log/yt-dlp/pot-provider.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/stephen/.local/log/yt-dlp/pot-provider.log</string>
