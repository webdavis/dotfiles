#!/bin/bash
# run_onchange_after_36-reload-yt-dlp-pot-launchagent.sh
# plist hash: {{ include "Library/LaunchAgents/com.webdavis.yt-dlp-pot-provider.plist.tmpl" | sha256sum }}

{{- if eq .chezmoi.os "darwin" }}
LABEL="com.webdavis.yt-dlp-pot-provider"
PLIST="${HOME}/Library/LaunchAgents/${LABEL}.plist"
DOMAIN="gui/$(id -u)"

if launchctl list "${LABEL}" &>/dev/null; then
  echo "Reloading PO token provider LaunchAgent..."
  launchctl bootout "${DOMAIN}/${LABEL}" 2>/dev/null || true
fi

launchctl bootstrap "${DOMAIN}" "${PLIST}" 2>/dev/null || true
{{- end }}
