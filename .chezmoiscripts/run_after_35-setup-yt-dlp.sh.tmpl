{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash

set -uo pipefail

# =============================================================================
# Configuration
# =============================================================================

YTDLP_BIN="${HOME}/.local/bin/yt-dlp"
YTDLP_URL="https://github.com/yt-dlp/yt-dlp/releases/latest/download/yt-dlp_macos"

POT_REPO="${HOME}/.local/share/yt-dlp/bgutil-ytdlp-pot-provider"
POT_SERVER="${POT_REPO}/server"
POT_REPO_URL="https://github.com/Brainicism/bgutil-ytdlp-pot-provider.git"
POT_API="https://api.github.com/repos/Brainicism/bgutil-ytdlp-pot-provider/releases/latest"
POT_PLUGIN_URL="https://github.com/Brainicism/bgutil-ytdlp-pot-provider/releases/latest/download/bgutil-ytdlp-pot-provider.zip"

PLUGIN_DIR="${HOME}/.config/yt-dlp/plugins"
PLUGIN_ZIP="${PLUGIN_DIR}/bgutil-ytdlp-pot-provider.zip"

LAUNCHAGENT_LABEL="com.webdavis.yt-dlp-pot-provider"
LAUNCHAGENT_PLIST="${HOME}/Library/LaunchAgents/${LAUNCHAGENT_LABEL}.plist"
LAUNCHAGENT_DOMAIN="gui/$(id -u)"

# =============================================================================
# Helpers
# =============================================================================

download_file() {
  local url="$1" dest="$2"
  local tmpfile
  tmpfile="$(mktemp)"
  if curl --proto '=https' --tlsv1.2 -L --fail --retry 3 -s -o "${tmpfile}" "${url}"; then
    mkdir -p "$(dirname "${dest}")"
    mv "${tmpfile}" "${dest}"
    return 0
  else
    rm -f "${tmpfile}"
    return 1
  fi
}

fetch_latest_pot_tag() {
  curl -sf "${POT_API}" | jq -r .tag_name 2>/dev/null
}

current_pot_tag() {
  git -C "${POT_REPO}" describe --tags --exact-match 2>/dev/null
}

build_pot_server() {
  echo "Building PO token server..."
  (cd "${POT_SERVER}" && deno install --allow-scripts=npm:canvas --frozen)
}

# =============================================================================
# Install
# =============================================================================

install_ytdlp() {
  [[ -x "${YTDLP_BIN}" ]] && return 0
  echo "Installing yt-dlp..."
  if download_file "${YTDLP_URL}" "${YTDLP_BIN}"; then
    chmod a+rx "${YTDLP_BIN}"
    echo "Switching to nightly channel..."
    "${YTDLP_BIN}" --update-to nightly || echo "Warning: failed to switch to nightly."
  else
    echo "Warning: failed to download yt-dlp."
    return 1
  fi
}

install_pot_server() {
  [[ -d "${POT_SERVER}/node_modules" ]] && return 0
  local tag
  tag="$(fetch_latest_pot_tag)" || true
  if [[ -z "${tag}" ]]; then
    echo "Warning: could not fetch latest bgutil release tag."
    return 1
  fi
  if [[ ! -d "${POT_REPO}" ]]; then
    echo "Cloning bgutil-ytdlp-pot-provider ${tag}..."
    mkdir -p "$(dirname "${POT_REPO}")"
    if ! git clone --single-branch --branch "${tag}" "${POT_REPO_URL}" "${POT_REPO}" 2>/dev/null; then
      echo "Warning: failed to clone bgutil repo."
      return 1
    fi
  fi
  build_pot_server || { echo "Warning: server build failed."; return 1; }
}

install_plugin() {
  [[ -f "${PLUGIN_ZIP}" ]] && return 0
  echo "Downloading bgutil plugin..."
  if ! download_file "${POT_PLUGIN_URL}" "${PLUGIN_ZIP}"; then
    echo "Warning: failed to download bgutil plugin."
    return 1
  fi
}

# =============================================================================
# Update
# =============================================================================

update_ytdlp() {
  [[ -x "${YTDLP_BIN}" ]] || return 0
  "${YTDLP_BIN}" -U 2>/dev/null || echo "Warning: yt-dlp update check failed."
}

update_pot_server() {
  [[ -d "${POT_REPO}" ]] || return 1
  local latest current
  latest="$(fetch_latest_pot_tag)" || true
  current="$(current_pot_tag)" || current=""
  [[ -n "${latest}" ]] && [[ "${current}" != "${latest}" ]] || return 1
  echo "Updating bgutil-ytdlp-pot-provider from ${current:-unknown} to ${latest}..."
  git -C "${POT_REPO}" fetch --tags origin 2>/dev/null
  if git -C "${POT_REPO}" checkout "${latest}" 2>/dev/null; then
    build_pot_server || { echo "Warning: server rebuild failed."; return 1; }
    return 0
  else
    echo "Warning: failed to checkout ${latest}."
    return 1
  fi
}

update_plugin() {
  echo "Re-downloading bgutil plugin to match server..."
  if ! download_file "${POT_PLUGIN_URL}" "${PLUGIN_ZIP}"; then
    echo "Warning: failed to re-download bgutil plugin."
  fi
}

# =============================================================================
# LaunchAgent
# =============================================================================

ensure_pot_launchagent() {
  [[ -f "${LAUNCHAGENT_PLIST}" ]] || return 1
  mkdir -p "${HOME}/.local/log/yt-dlp"
  if launchctl list "${LAUNCHAGENT_LABEL}" &>/dev/null; then
    return 0
  fi
  echo "Loading PO token provider LaunchAgent..."
  launchctl bootstrap "${LAUNCHAGENT_DOMAIN}" "${LAUNCHAGENT_PLIST}" 2>/dev/null || true
}

restart_pot_launchagent() {
  launchctl list "${LAUNCHAGENT_LABEL}" &>/dev/null || return 0
  echo "Restarting PO token provider..."
  launchctl kickstart -k "${LAUNCHAGENT_DOMAIN}/${LAUNCHAGENT_LABEL}" 2>/dev/null || true
}

# =============================================================================
# Main
# =============================================================================

main() {
  if ! command -v deno &>/dev/null || ! command -v jq &>/dev/null; then
    echo "Warning: required tools not yet available. Skipping yt-dlp setup."
    return 0
  fi

  install_ytdlp
  install_pot_server
  install_plugin

  update_ytdlp
  if update_pot_server; then
    update_plugin
    restart_pot_launchagent
  fi

  ensure_pot_launchagent

  echo "yt-dlp setup complete."
}

main
{{ end -}}
