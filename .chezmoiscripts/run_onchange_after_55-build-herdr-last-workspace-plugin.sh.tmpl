{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash

set -euo pipefail

# Builds and links the last-workspace herdr plugin (a true MRU workspace toggle
# herdr lacks natively). `herdr plugin link` does NOT run the manifest's
# [[build]] step, so the binary is compiled here. Re-runs whenever the plugin
# source changes (run_onchange keyed on the rendered content below).
#
{{ includeTemplate "herdr-plugin-build.sh.tmpl" (dict "id" "herdr-last-workspace") }}
# Seed the MRU 'current' with the live focused workspace so the first bounce
# after install works. The plugin learns workspaces only as they are focused, so
# without this seed the workspace focused at install time is missing until it is
# re-focused (the event-only cold-start gap). Only seed when no state exists yet.
state="${XDG_STATE_HOME:-$HOME/.local/state}/herdr/plugins/${plugin_id}/mru"
if [[ ! -s $state ]]; then
  focused=$(herdr workspace list 2>/dev/null | jq -r '[.result.workspaces[] | select(.focused) | .workspace_id][0] // empty')
  if [[ -n $focused ]]; then
    mkdir -p "$(dirname "$state")"
    printf '%s\n\n' "$focused" >"$state"
  fi
fi
{{ end -}}
