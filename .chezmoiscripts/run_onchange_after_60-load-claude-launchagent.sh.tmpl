#!/bin/bash
# run_onchange_after_60-load-claude-launchagent.sh
# plist hash: {{ include "Library/LaunchAgents/com.claude.code.plist.tmpl" | sha256sum }}

{{- if eq .chezmoi.os "darwin" }}
launchctl unload ~/Library/LaunchAgents/com.claude.code.plist 2>/dev/null
launchctl load ~/Library/LaunchAgents/com.claude.code.plist
{{- end }}
