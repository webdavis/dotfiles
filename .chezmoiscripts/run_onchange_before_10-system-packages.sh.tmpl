{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash

set -euo pipefail

# Use `brew bundle ...` to install all taps, formulae, casks, and macOS App Store apps.
/opt/homebrew/bin/brew bundle --cleanup --file=/dev/stdin <<EOF
{{ range .packages.macos.homebrew.taps -}}
tap {{ . | quote }}
{{ end -}}
{{ range .packages.macos.homebrew.formulae -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.macos.homebrew.casks -}}
cask {{ . | quote }}
{{ end -}}
{{ range .packages.macos.homebrew.mas -}}
mas {{ .name | quote }}, id: {{ .id }}
{{ end -}}
EOF

# Restart `skhd` hotkey daemon.
skhd --restart-service

# Configure Hombrew autoupdate.
HOMBREW_BIN="${HOMEBREW_PREFIX:-/opt/homebrew}/bin/brew"

# Workaround to reset the startup timestamp for `domt4/autoupdate` daemon.
echo "Restarting domt4/autoupdate [stop → delete → start]..."
"$HOMBREW_BIN" autoupdate stop
"$HOMBREW_BIN" autoupdate delete
"$HOMBREW_BIN" autoupdate start 86400 --upgrade --cleanup --immediate --sudo

# Install uv tools (runs after Homebrew so uv is available).
{{ range .packages.macos.uv_tools -}}
/opt/homebrew/bin/uv tool install {{ . | quote }}
{{ end -}}

# Install bun global packages (runs after Homebrew so bun is available).
{{ range .packages.macos.bun_global -}}
/Users/stephen/.bun/bin/bun install -g {{ . | quote }}
{{ end -}}
{{ end -}}
