{{ if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash

set -euo pipefail

echo "Setting up osquery..."

# Create osquery flags directory and config pointer.
sudo mkdir -p /var/osquery
echo "--config_path={{ .chezmoi.homeDir }}/.config/osquery/osquery.conf" | sudo tee /var/osquery/osquery.flags >/dev/null

# Create log and report directories.
mkdir -p "$HOME/.local/log/osquery"
mkdir -p "${OSQUERY_REPORT_DIR:-$HOME/.local/state/osquery-reports}"

# Load the LaunchAgent for the report script.
launchctl load -w "$HOME/Library/LaunchAgents/com.webdavis.osquery-report.plist" 2>/dev/null || true

# Start osqueryd.
sudo osqueryctl start || true

echo "osquery setup complete."
{{ end -}}
