{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash

set -euo pipefail

echo "Setting up osquery..."

# Create osquery flags directory and config pointer.
sudo mkdir -p /var/osquery
echo "--config_path={{ .chezmoi.homeDir }}/.config/osquery/osquery.conf" | sudo tee /var/osquery/osquery.flags >/dev/null

# Create log and report directories.
mkdir -p "$HOME/.local/log/osquery"
mkdir -p "${OSQUERY_REPORT_DIR:-$HOME/.local/state/osquery-reports}"

# Load the LaunchAgent for the report script (modern bootstrap, not the
# deprecated load -w). Bootout-then-bootstrap is the launchctl-1 idiom for
# "(re)load this unit"; legacy load is being phased out by Apple.
launchctl bootout "gui/$(id -u)/com.webdavis.osquery-report" 2>/dev/null || true
launchctl bootstrap "gui/$(id -u)" "$HOME/Library/LaunchAgents/com.webdavis.osquery-report.plist" 2>/dev/null || true

# Start osqueryd. Redirect output because osqueryctl prints 'Load failed: 5'
# to stdout on subsequent runs (the daemon is already loaded); the exit code
# is swallowed by '|| true'.
sudo osqueryctl start >/dev/null 2>&1 || true

echo "osquery setup complete."
{{ end -}}
