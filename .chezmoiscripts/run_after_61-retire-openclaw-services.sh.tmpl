{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash

set -euo pipefail

# Convergent retirement of the live OpenClaw services this host still runs from
# earlier applies. The repo removal deleted the OpenClaw config and package
# declarations but never retired what was already installed, so the dead gateway
# launchd agent (its module gone) retry-loops forever. This script boots out the
# three known agents (gateway, node, rescue), deletes their plists, and
# uninstalls the global npm `openclaw` package.
#
# It is a run_after, NOT a run_once: run_once records success permanently even
# when a probe or action transiently failed, which would strand a
# partially-retired host. Instead it gates on a quiescence marker: once a full
# postcondition sweep confirms every label is gone, every plist is gone, and npm
# openclaw is gone, it writes the marker and every later apply is a single file
# check. Anything short of full convergence leaves the marker unwritten and the
# next apply retries.
#
# It is deliberately narrow: it names ONLY the three exact labels (never a
# wildcard, never a fuzzy label scan), and it MUST NOT touch ~/.openclaw -- the
# vendored elevenlabs skill uses ~/.openclaw/elevenlabs/ as its data dir. Every
# path exits 0 (a retirement chore must never abort `chezmoi apply`), internal
# failures are warnings, and each real action prints one loud line.

log() { printf 'openclaw-retire: %s\n' "$*"; }
warn() { printf 'openclaw-retire: WARN %s\n' "$*" >&2; }

state_dir="$HOME/.local/state/openclaw"
marker="$state_dir/retired"

# Fast path: once fully retired, every subsequent apply costs one file check.
if [[ -f $marker ]]; then
  exit 0
fi

uid="$(id -u)"
launch_agents_dir="$HOME/Library/LaunchAgents"

# The ONLY launchd labels this script may ever touch. No wildcards, no prefix
# matches -- the plist filenames are derived from these exact names.
labels=(
  ai.openclaw.gateway
  ai.openclaw.node
  ai.openclaw.rescue
)

# `launchctl print <service>` exits 0 when the service is loaded and with a known
# not-found status when it is absent. That status, verified live (113 = confirmed
# absent; 112 = an operational error such as an invalid GUI domain). Treat the
# probe as TRI-STATE: 0 = loaded, 113 = confirmed absent, anything else = an
# operational error whose result must NOT be interpreted as either state -- a
# nonzero-but-not-113 must never be misread as "unloaded", which would let an
# operational error delete a plist and write the permanent marker while the job
# is still loaded. Mirrors run_after_56/59. Only a CONFIRMED absence permits plist
# removal and counts toward the quiescence marker.
not_found_status=113

# launchd_state <target> : echoes loaded | absent | unknown.
launchd_state() {
  local status=0
  launchctl print "$1" >/dev/null 2>&1 || status=$?
  if [[ $status -eq 0 ]]; then
    printf 'loaded'
  elif [[ $status -eq $not_found_status ]]; then
    printf 'absent'
  else
    printf 'unknown'
  fi
}

# npm_openclaw_state : echoes installed | absent | unknown. `npm ls` shares the
# probe ambiguity -- a non-zero exit can mean "absent" OR "npm could not answer"
# -- so the verdict is parsed from the --json tree, not the exit code: a parseable
# object with a .dependencies.openclaw entry is installed, a parseable object
# without one is confirmed absent, and an unparseable answer or an error envelope
# is unknown (could not determine). A MISSING npm binary is "unknown", NOT
# "absent": a system-only PATH (an automation env) can hide Homebrew's npm, and
# calling that confirmed-absent would write the PERMANENT quiescence marker while
# the global package silently survives. Indeterminate withholds the marker and
# retries next apply.
npm_openclaw_state() {
  if ! command -v npm >/dev/null 2>&1; then
    printf 'unknown'
    return 0
  fi
  local json verdict
  json="$(npm ls -g openclaw --json 2>/dev/null)" || true
  verdict="$(printf '%s' "$json" |
    jq -r '
      if type == "object" then
        (if has("error") then "unknown"
         elif (.dependencies.openclaw != null) then "installed"
         else "absent" end)
      else "unknown" end' 2>/dev/null || printf 'unknown')"
  case "$verdict" in
    installed | absent | unknown) printf '%s' "$verdict" ;;
    *) printf 'unknown' ;;
  esac
}

# services_all_retired stays true only if EVERY label ends confirmed absent AND
# every plist is gone. It gates the npm uninstall below: uninstalling the package
# while any openclaw launchd job is still loaded (or its state is unknown) would
# pull /opt/homebrew/lib/node_modules/openclaw/dist/index.js out from under a
# running KeepAlive job. Any label left loaded/unknown, or any plist that
# survives, flips it false and defers the uninstall to a later apply.
services_all_retired=true
for label in "${labels[@]}"; do
  target="gui/$uid/$label"
  state="$(launchd_state "$target")"
  if [[ $state == loaded ]]; then
    if launchctl bootout "$target" >/dev/null 2>&1; then
      log "booted out $target"
      # Re-probe: only a CONFIRMED absence lets the plist go.
      state="$(launchd_state "$target")"
    else
      warn "failed to bootout $target; leaving its plist for the next apply to retry"
    fi
  fi

  # Ordering: remove the plist ONLY when the label is confirmed absent (113).
  # While loaded OR unknown (an operational probe error), retain it -- removing a
  # plist whose job is still loaded, or whose state we could not determine,
  # orphans the running job.
  if [[ $state != absent ]]; then
    if [[ $state == unknown ]]; then
      warn "could not determine the load state of $target (launchctl print returned an unexpected status); leaving its plist for the next apply to retry"
    fi
    services_all_retired=false
    continue
  fi
  plist="$launch_agents_dir/$label.plist"
  if [[ -e $plist ]]; then
    if rm -f "$plist" >/dev/null 2>&1; then
      log "removed $plist"
    else
      warn "failed to remove $plist"
    fi
  fi
  # A plist that survived removal (still loaded elsewhere would already have
  # continued above; this catches a failed rm) leaves the service not fully gone.
  if [[ -e $plist ]]; then
    services_all_retired=false
  fi
done

# Uninstall the global npm package, but ONLY when every launchd label is
# confirmed absent AND every plist is gone (services_all_retired) AND npm
# confirms the package installed. If the services are not fully retired, the
# uninstall is deferred so the package is not pulled out from under a still-loaded
# job. An indeterminate npm probe (unknown) never triggers an uninstall and never
# counts as retired -- it warns and holds the marker.
npm_state="$(npm_openclaw_state)"
if [[ $services_all_retired != true ]]; then
  if [[ $npm_state != absent ]]; then
    warn "openclaw launchd services are not fully retired yet; deferring the npm uninstall so the package is not pulled out from under a still-loaded job (retry next apply)"
  fi
elif [[ $npm_state == installed ]]; then
  if npm uninstall -g openclaw >/dev/null 2>&1; then
    log "uninstalled global npm package openclaw"
  else
    warn "failed to uninstall global npm package openclaw"
  fi
elif [[ $npm_state == unknown ]]; then
  warn "could not determine whether the global npm package openclaw is installed; leaving it for the next apply to retry"
fi

# Postcondition sweep: only a fully verified state writes the marker. Re-probe
# each label (tri-state -- only a confirmed absence counts), each plist, and npm;
# anything not confirmed gone is listed loudly with the exact manual command, and
# the marker stays unwritten so the next apply retries.
remaining=()
for label in "${labels[@]}"; do
  target="gui/$uid/$label"
  state="$(launchd_state "$target")"
  if [[ $state != absent ]]; then
    remaining+=("launchd job $target not confirmed unloaded (state: $state; manual: launchctl bootout $target)")
  fi
  plist="$launch_agents_dir/$label.plist"
  if [[ -e $plist ]]; then
    remaining+=("plist $plist still present (manual: rm -f $plist)")
  fi
done
npm_state="$(npm_openclaw_state)"
if [[ $npm_state != absent ]]; then
  remaining+=("global npm package openclaw not confirmed absent (state: $npm_state; manual: npm uninstall -g openclaw)")
fi

# The mkdir + marker write are GUARDED: under `set -euo pipefail` an unwritable
# state dir (a root-owned leftover) would otherwise abort the whole apply. A
# failed write warns, does NOT claim completion, and still exits 0 so the next
# apply retries.
if [[ ${#remaining[@]} -eq 0 ]]; then
  if mkdir -p "$state_dir" 2>/dev/null && : >"$marker" 2>/dev/null; then
    log "retirement complete; wrote quiescence marker $marker"
  else
    warn "openclaw retirement converged but the quiescence marker $marker could not be written (state dir unwritable?); NOT claiming completion. The next chezmoi apply will retry."
  fi
else
  warn "openclaw retirement incomplete; NOT writing the marker. Remaining:"
  for item in "${remaining[@]}"; do
    warn "  - $item"
  done
  warn "the next chezmoi apply will retry."
fi

exit 0
{{- end }}
