#!/usr/bin/env bash

# This script currently utilizes the following third-party tools:
#   - OpenHue (https://www.openhue.io/).
#   - jq (https://jqlang.org/)
#   - GNU getopt (https://formulae.brew.sh/formula/gnu-getopt)

# Exit immediately if any command fails.
set -euo pipefail

# ANSI colors (only when stdout is a terminal)
if [ -t 1 ]; then
  CLR_GREEN='\033[0;32m'
  CLR_RED='\033[0;31m'
  CLR_YELLOW='\033[0;33m'
  CLR_CYAN='\033[0;36m'
  CLR_RESET='\033[0m'
else
  CLR_GREEN=''; CLR_RED=''; CLR_YELLOW=''; CLR_CYAN=''; CLR_RESET=''
fi

set_debug_log() {
  # Capture all messages to the debug log.

  script_debug_log="$HOME/Library/Logs/smart-lights.log"

  # Save the original stdout to file descriptor 3.
  exec 3>&1

  # Redirect all output to the log file by default.
  exec >>"$script_debug_log" 2>&1

  # Log the script start time.
  echo "Script started at $(date '+%Y-%m-%d %H:%M:%S')"
}

log_message() {
  # Function to log and optionally print to stdout.
  local message="$1"
  local to_stdout="${2:-false}" # Default to not printing to stdout
  local color="${3:-}"          # Optional ANSI color code

  # Log the message to the debug log (no color)
  echo "$message"

  # If to_stdout is true, print to stdout using the original STDOUT descriptor.
  if [[ $to_stdout == "true" ]]; then
    if [[ -n $color ]]; then
      printf "${color}%s${CLR_RESET}\n" "$message" >&3
    else
      echo "$message" >&3
    fi
  fi
}

notify() {
  # GUI notification via macOS — only fires if --notify flag was passed.
  local message="$1"
  if [[ ${NOTIFY:-false} == "true" ]]; then
    osascript -e "display notification \"$message\" with title \"Smart Lights\"" 2>/dev/null || true
  fi
}

help_message() {
  local bold normal script_name
  bold=$(tput bold 2>/dev/null || echo "")
  normal=$(tput sgr0 2>/dev/null || echo "")
  script_name="${BASH_SOURCE[0]##*/}"

  printf '%s\n' "\

${bold}DESCRIPTION${normal}
   Controls Philips Hue lights via OpenHue. Defaults to the 3F - Studio room.

${bold}USAGE${normal}
   ${script_name} [OPTIONS]

${bold}OPTIONS${normal}
   -p, --power              Toggle room power on/off
   -b, --brightness <dir>   Adjust brightness: up or down (steps of 15%)
   -s, --scene <name>       Set a scene by name, or use: next, previous
   -S, --status             Print current power state, brightness, and scene
   -r, --room <name>        Target room (default: 3F - Studio)
   -N, --notify             Show a macOS GUI notification after the action
   -h, --help               Print this help text

${bold}SCENES (rotation order)${normal}
   Dimmed       Soft ambient light
   Read         Balanced task light
   Energize     Bright cool light
   Concentrate  Focused work light

${bold}EXAMPLES${normal}
   ${script_name}                          Toggle studio lights on/off
   ${script_name} --brightness up          Increase brightness by 15%
   ${script_name} --scene Concentrate      Set scene to Concentrate
   ${script_name} --scene next             Rotate to next scene
   ${script_name} --status                 Show current room state
   ${script_name} --power --notify         Toggle power + macOS notification"
}

function cleanup() {
  # Exit with the status of the command that triggered this trap.
  local status=$?

  if [[ $status -gt 0 ]]; then
    printf "\nFAILED: Script encountered an error.\n\n" >&2
  else
    printf "\nSUCCESS: Script ended successfully.\n\n"
  fi

  exit $status
}

function setup_signal_handling() {
  # Handle process interuption signals.
  trap cleanup SIGINT SIGTERM

  # Handle the EXIT signal for any script termination.
  trap cleanup EXIT
}

check_requirements() {
  # Ensure we're using GNU getopt.
  declare -g GETOPT_CMD
  GETOPT_CMD="$(which getopt)"

  local gnu_getopt_path='/opt/homebrew/opt/gnu-getopt/bin'

  if [[ ${GETOPT_CMD%/*} != "$gnu_getopt_path" ]]; then
    if [[ -x $gnu_getopt_path ]]; then
      GETOPT_CMD="$gnu_getopt_path/getopt"
    else
      log_message "Error: GNU getopt not found. Please install it with 'brew install gnu-getopt'." true
      exit 1
    fi
  fi

  if ! command -v openhue &>/dev/null; then
    log_message "Error: 'openhue' command not found. Please install 'openhue' to continue (https://www.openhue.io/cli/installation)" true
    exit 1
  fi

  if ! command -v jq &>/dev/null; then
    log_message "Error: 'jq' command not found. Please install 'jq' to continue." true
    exit 1
  fi
}

resolve_room_alias() {
  local room="$1"
  case "$room" in
    studio)   echo "3F - Studio" ;;
    bedroom)  echo "3F - Master Bedroom" ;;
    kitchen)  echo "2F - Kitchen" ;;
    *)        echo "$room" ;;
  esac
}

get_room_status() {
  local id="$1"

  local json_path='.GroupedLight.HueData.on.on'

  local status
  status="$(openhue get room "$id" --json | jq "$json_path")"

  echo "$status"
}

set_room_power() {
  local room="$1"
  local id="$2"
  local state="$3"

  openhue set room "$id" "--${state}" >/dev/null
  if [[ $state == "on" ]]; then
    log_message "$room: $state" true "$CLR_GREEN"
    notify "$room lights on"
  else
    log_message "$room: $state" true "$CLR_RED"
    notify "$room lights off"
  fi
}

toggle_power() {
  local room="$1"

  local id
  id="$(get_room_id "$room")"

  local status
  status="$(get_room_status "$id")"

  if [[ $status == 'false' ]]; then
    set_room_power "$room" "$id" "on"
  else
    set_room_power "$room" "$id" "off"
  fi
}

get_static_scene() {
  # 'static' is the term used by OpenHue to represent the current scene.
  # It essentially means "active."
  local room="$1"

  local name
  name="$(openhue get scene --room "$room" --json | jq -r '.[] | select(.HueData.status.active == "static") | .Name')" || {
    log_message "Error: Failed to get scene for room: '$room'" true
    return 1
  }

  echo "$name"
}

rotate_scene() {
  local scene_name="$1"
  local direction="$2"

  local scenes=('Dimmed' 'Read' 'Energize' 'Concentrate')

  local index=""
  for i in "${!scenes[@]}"; do
    if [[ ${scenes[i]} == "$scene_name" ]]; then
      index=$i
      break
    fi
  done

  if [[ -z $index ]]; then
    # Fallback to "Read" if the scene is not recognized.
    echo 'Read'
    return
  fi

  local next_index
  if [[ $direction == 'next' ]]; then
    next_index=$(((index + 1) % ${#scenes[@]}))
  else
    next_index=$(((index - 1) % ${#scenes[@]}))
  fi

  echo "${scenes[next_index]}"
}

get_room_id() {
  local room="$1"

  local id
  id="$(openhue get room --json | jq -r --arg room "$room" 'limit(1; .. | select(.Name? == $room) | .Id)')"

  echo "$id"
}

get_scene_id() {
  local room_id="$1"
  local scene_name="$2"

  local scene_id
  scene_id="$(openhue get room "$room_id" --json | jq -r --arg scene "$scene_name" '.. | select(.metadata?.name == $scene) | .id')"

  echo "$scene_id"
}

get_brightness() {
  local room="$1"

  local json_path='.GroupedLight.HueData.dimming.brightness'

  local brightness
  brightness="$(openhue get room "$room" --json | jq "$json_path")"

  echo "${brightness%%.*}"
}

set_brightness() {
  local room="$1"
  local id="$2"
  local brightness="$3"
  local direction="${4:-up}"

  openhue set room "$id" -b "$brightness"

  if [[ $direction == "up" ]]; then
    log_message "🔆 Room: $room | Current brightness: ${brightness}%" true "$CLR_GREEN"
    notify "$room brightness up to ${brightness}%"
  else
    log_message "🔅 Room: $room | Current brightness: ${brightness}%" true "$CLR_YELLOW"
    notify "$room brightness down to ${brightness}%"
  fi
}

validate_room_id() {
  # Check if the room ID was found.

  local room="$1"
  local id="$2"

  if [[ -z $id ]]; then
    log_message "Error: Room ID for '$room' not found. Please ensure the room name is correct." true
    exit 1
  fi
}

manage_brightness() {
  local direction="$1"
  local room="$2"

  # Validate inputs
  if [[ -z $direction || -z $room ]]; then
    log_message "Error: Both direction and room must be provided." true
    return 1
  fi

  if [[ ! $direction =~ ^(up|down)$ ]]; then
    log_message "Error: Direction must be 'up' or 'down'." true
    return 1
  fi

  local id
  id="$(get_room_id "$room")"

  validate_room_id "$room" "$id"

  local current_brightness
  current_brightness="$(get_brightness "$room")"

  # Calculate new brightness.
  local adjustment=15
  local brightness="$current_brightness"
  if [[ $direction == 'up' ]]; then
    brightness=$((brightness + adjustment))
  else
    brightness=$((brightness - adjustment))
  fi

  if ((brightness < 0)); then
    brightness=0
  elif ((brightness > 100)); then
    brightness=100
  fi

  set_brightness "$room" "$id" "$brightness" "$direction"
}

validate_scene_id() {
  # Check if the scene ID was found.

  local scene="$1"
  local id="$2"
  local room="$3"

  if [[ -z $id ]]; then
    log_message "Error: Unable to find the Scene ID for scene '$scene' in room '$room'." true
    exit 1
  fi
}

set_scene() {
  local room="$1"
  local id="$2"
  local scene="$3"

  openhue set scene "$id" >/dev/null
  log_message "Room: $room | Scene: $scene" true "$CLR_CYAN"
  notify "$room scene: $scene"
}

handle_scene_logic() {
  local scene_name="$1"
  local room="$2"

  if [[ $scene_name =~ ^(next|previous)$ ]]; then
    local current_scene
    current_scene="$(get_static_scene "$room")"

    scene_name="$(rotate_scene "$current_scene" "$scene_name")"
  fi

  local room_id
  room_id="$(get_room_id "$room")"

  validate_room_id "$room" "$room_id"

  local scene_id
  scene_id="$(get_scene_id "$room_id" "$scene_name")"

  validate_scene_id "$scene_name" "$scene_id" "$room"

  set_scene "$room" "$scene_id" "$scene_name"
}

show_status() {
  local room="$1"

  local id
  id="$(get_room_id "$room")"
  validate_room_id "$room" "$id"

  local on
  on="$(get_room_status "$id")"

  local brightness
  brightness="$(get_brightness "$room")"

  local scene
  scene="$(get_static_scene "$room")" || scene="unknown"

  if [[ $on == "true" ]]; then
    log_message "$room: ON | brightness: ${brightness}% | scene: $scene" true "$CLR_GREEN"
  else
    log_message "$room: OFF | brightness: ${brightness}% | scene: $scene" true "$CLR_RED"
  fi
}

parse_command_line_arguments() {
  local short='pr:b:nls:NSh'
  local long='power,room:,brightness:,next,last,scene:,notify,status,help'
  OPTIONS="$($GETOPT_CMD -o "$short" --long "$long" -- "$@")"
  eval set -- "$OPTIONS"

  # Default values
  NOTIFY='false'
  local status_only='false'
  local power='false'
  local brightness=''
  local scene=''
  local room='3F - Studio'

  while true; do
    case "$1" in
      -p | --power)
        power='true'
        shift
        ;;
      -r | --room)
        room="$(resolve_room_alias "$2")"
        shift 2
        ;;
      -b | --brightness)
        brightness="$2"
        shift 2
        ;;
      -s | --scene)
        scene="$2"
        shift 2
        ;;
      -N | --notify)
        NOTIFY='true'
        shift
        ;;
      -S | --status)
        status_only='true'
        shift
        ;;
      -h | --help)
        help_message >&3
        exit 0
        ;;
      --)
        shift
        break
        ;;
      *)
        log_message "Invalid: Unknown option: $1" true
        exit 1
        ;;
    esac
  done

  if [[ $status_only == 'true' ]]; then
    show_status "$room"
  elif [[ $power == 'true' ]]; then
    toggle_power "$room"
  elif [[ -n $brightness ]]; then
    manage_brightness "$brightness" "$room"
  elif [[ -n $scene ]]; then
    handle_scene_logic "$scene" "$room"
  fi
}

main() {
  set_debug_log
  setup_signal_handling
  check_requirements
  parse_command_line_arguments "$@"
}

if [[ $# -eq 0 ]]; then
  main "-p"
else
  main "$@"
fi
