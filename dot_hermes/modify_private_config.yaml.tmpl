{{- /*
  modify_ template -> ~/.hermes/config.yaml. Ensures the webhook base (enabled + host/port defaults) and
  sets routes.relay (webhook secret + Discord channel id from KeePassXC), preserving the osquery routes and
  anything `hermes setup` wrote. The merge expression lives in private/relay-hermes-route.yq (unit-tested by
  test/relay-hermes-route.sh). It is idempotent and self-sufficient -- it works on an existing, an empty, or
  a no-webhook config, so it does not depend on `hermes setup` having run first and re-asserts the route on
  every apply. Replaces the old create_ template.

  keepassxc-gated -> renders on interactive applies only; fails/skips headless (config.yaml is on the
  "never bare chezmoi apply from automation" list). Does NOT restart hermes: a restart drains in-flight
  runs and the route changes ~never, so run_after_68 only *reminds* you when a restart is owed. On yq
  failure (e.g. a malformed live config) the original is passed through unchanged rather than half-written.
*/ -}}
#!/bin/bash
set -euo pipefail
export SECRET={{ (keepassxc "Hermes :: Webhook Secret :: #relay").Password | quote }}
export CHATID={{ (keepassxc "Discord (Uriel) :: Channel ID (#relay)").Password | quote }}
cfg="$(cat)"
merged="$(printf '%s' "$cfg" | yq '{{ include "private/relay-hermes-route.yq" | trim }}')" || merged="$cfg"
printf '%s\n' "$merged"
