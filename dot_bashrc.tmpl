# shellcheck shell=bash
# vi:filetype=sh shiftwidth=2 softtabstop=2 tabstop=8:

# Opt-in shell startup profiling.
# Usage: BASHRC_PROFILE=1 bash -i -c exit 2>/tmp/bashrc.trace
[[ -n ${BASHRC_PROFILE:-} ]] && {
  PS4='+ $EPOCHREALTIME '
  set -x
}

# ┏━━━━━━━━━━━━━━━━━━━━┓
# ┃  Helper Functions  ┃
# ┗━━━━━━━━━━━━━━━━━━━━┛

# Prepend a directory to PATH.
# Usage:
#    $ path_prepend ~/foo/bin
#    $ export PATH
function path_prepend() {
  local dir="$1"

  if [[ -d $dir ]]; then
    PATH="$dir:$PATH"
  else
    echo "Directory $dir does not exist." >&2
    return 1
  fi
}

# ┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓
# ┃  Global Environment Variables & Settings  ┃
# ┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛
EDITOR="$(which nvim)" && export EDITOR
export BASH_SILENCE_DEPRECATION_WARNING=1
export MANPAGER="nvim +Man!"
export COLORTERM=truecolor
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_CONFIG_HOME="$HOME/.config"
export LC_ALL=en_US.UTF-8
export LANG=en_US.UTF-8
export USER="${USER:-$(whoami)}"

# Bash history is handled entirely by atuin's daemon (v2 §1.1). Bash built-in
# history flags (HISTFILE, HISTSIZE, histappend, HISTCONTROL, HISTIGNORE) were
# removed to eliminate race conditions across herdr panes and redundant writes.

[[ -f "$HOME/.atuin/bin/env" ]] && . "$HOME/.atuin/bin/env"

# ┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓
# ┃  Homebrew: https://brew.sh/ ┃
# ┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛
HOMEBREW_PREFIX='/opt/homebrew'

# Configure homebrew_prefix/bin tools.
eval "$(${HOMEBREW_PREFIX}/bin/brew shellenv)"

# Configure Homebrew system administrator tools.
path_prepend "${HOMEBREW_PREFIX}/sbin"

export SHELL="${HOMEBREW_PREFIX}/bin/bash"

# General Homebrew-Bash completions.
bash_completion="${HOMEBREW_PREFIX}/opt/bash-completion@2/etc/profile.d/bash_completion.sh"
[[ -r $bash_completion ]] && . "$bash_completion"

# bash-preexec: provides preexec_functions/precmd_functions arrays that atuin
# and the long-running command notifier depend on. Must load BEFORE atuin init
# so atuin's hooks register with it. Newer atuin (>= 18.x) no longer bundles it.
# Ref: https://github.com/rcaloras/bash-preexec
bash_preexec="${HOMEBREW_PREFIX}/etc/profile.d/bash-preexec.sh"
[[ -r $bash_preexec ]] && . "$bash_preexec"

# Configure updated curl.
path_prepend "${HOMEBREW_PREFIX}/opt/curl/bin"

# Configure https://github.com/andreafrancia/trash-cli
path_prepend "${HOMEBREW_PREFIX}/opt/trash-cli/bin/"

path_prepend "${HOMEBREW_PREFIX}/opt/gnu-getopt/bin/"

export MANPATH="${HOMEBREW_PREFIX}/share/man:${MANPATH}"

# ┏━━━━━━━━━━━━━━━━━━━━━┓
# ┃  3rd Party Tooling  ┃
# ┗━━━━━━━━━━━━━━━━━━━━━┛

# git and gh completions are provided by carapace (below) and, for git, the
# completion bundled with Homebrew's git formula, both lazy-loaded, so nothing
# to source here.

# Direnv: https://github.com/direnv/direnv
eval "$(direnv hook bash)" # Sets the Direnv hook.

# Carapace: universal shell completion engine (v2 §16.3).
# Ref: https://github.com/carapace-sh/carapace-bin
# CARAPACE_MATCH=1 enables case-insensitive matching. Carapace registers
# `complete -F _carapace_completer` for ~700 commands (ls, cat, vim, git, …)
# and writes COMPREPLY directly, so readline's `completion-ignore-case` does
# NOT apply to those commands. Without this env var, lowercase prefixes won't
# match uppercase filenames despite inputrc settings.
# Docs: https://carapace-sh.github.io/carapace-bin/setup/environment.html
export CARAPACE_MATCH=1
command -v carapace &>/dev/null && source <(carapace _carapace bash) 2>/dev/null

# Composio CLI
# Ref: https://docs.composio.dev/docs/cli
export COMPOSIO_INSTALL_DIR="$HOME/.composio"
export PATH="$COMPOSIO_INSTALL_DIR:$PATH"

# Starship: https://starship.rs/
# Use simplified ASCII config when connecting via Mosh or SSH.
if [[ -n ${MOSH_KEY:-} || -n ${SSH_CONNECTION:-} ]]; then
  export STARSHIP_CONFIG="$HOME/.config/starship-mosh.toml"
fi
eval "$(starship init bash)"

# Cargo: https://github.com/rust-lang/cargo
# Direct PATH add instead of sourcing .cargo/env (avoids file read on every shell start).
[[ -d "$HOME/.cargo/bin" ]] && path_prepend "$HOME/.cargo/bin"

# Volta: https://volta.sh/
# Append (not prepend) so Volta's node/npm shims do NOT win over Homebrew's
# `node`. Volta-installed CLI tools (e.g. qmd) still resolve here because
# nothing earlier in PATH provides those binaries, and their shims dispatch to
# their pinned Node version internally, independent of PATH order.
export VOLTA_HOME="$HOME/.volta"
[[ -d "$VOLTA_HOME/bin" ]] && PATH="$PATH:$VOLTA_HOME/bin"

# Just: https://github.com/casey/just
[[ -s "$HOME/.bash_just_completions" ]] && . "$HOME/.bash_just_completions"
# Ref: https://github.com/casey/just?tab=readme-ov-file#shell-alias
alias j='just'
complete -F _just -o bashdefault -o default j

# Worktrunk: https://worktrunk.dev/
# Defines a `wt` shell function wrapping the binary so `wt switch`/`wt merge`
# can change the parent shell's directory (a subprocess can't cd its caller,
# the function reads a directive temp file and runs the cd itself). Without it,
# `wt switch` finds the worktree but cannot move you there. The init output is
# self-guarding (`if command -v wt`) and uses `builtin cd`, so it is inert when
# wt is absent and unaffected by zoxide's later `cd` alias. No PROMPT_COMMAND
# mutation, so placement here (before zoxide/atuin) is safe.
eval "$(wt config shell init bash)"

# Nix: https://github.com/NixOS/nix-installer
nix_daemon='/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh'
[[ -e $nix_daemon ]] && . "$nix_daemon"

# ┏━━━━━━━━━━━━━━━━━━━━━┓
# ┃  Utility functions  ┃
# ┗━━━━━━━━━━━━━━━━━━━━━┛
# Sourced from ~/.bash_functions for organization. Loaded outside the
# interactive guard so functions are available to non-interactive
# sub-shells too (e.g. `bash -c 'mkd /tmp/foo'`).
[[ -s "$HOME/.bash_functions" ]] && . "$HOME/.bash_functions"

# Per-command Bash completions live in ~/.local/share/bash-completion/completions/
# and are lazy-loaded by bash-completion@2's dynamic loader (sourced above) on
# first tab, nothing to source here. Add a file named after the command (e.g.
# `whisply`), no extension.

# Fzf: ~/.fzf_bindings (sourced later in the interactive block) loads only
# key-bindings.bash, NOT completion.bash. Sourcing ~/.fzf.bash here would
# pull in completion.bash, which registers `complete -F _fzf_path_completion`
# for ~50 commands and breaks readline's `completion-ignore-case` for them.
# See https://github.com/junegunn/fzf/tree/master/shell.

# ┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓
# ┃  Interactive-only features  ┃
# ┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛
if [[ $- == *i* ]]; then
  # Zoxide alias.
  alias cd='z'

  # Modern tool aliases (v2 §16.1).
  alias ls='eza --icons'
  alias ll='eza -la --git --icons'
  alias la='eza -a --icons'
  alias lt='eza --tree --level=2 --icons --git-ignore'
  alias cp='cp -i'
  alias mv='mv -i'
  alias bat='bat --color=always'
  alias tree='tree -C'
  alias du='dust'
  alias ps='procs'
  alias grep='grep --color=auto'
  alias p='python3'
  alias git-weekly='git diff --name-status "@{7 days ago}" | sort -u | grep -v "Templates" > weekly-review-files.md'
  alias path='echo $PATH | tr ":" "\n"'
  alias h='herdr-jump.sh homelab "$HOME/workspaces/Ivy/webdavis/homelab"'
  alias fman='compgen -c | fzf | xargs man'

  # Custom git wrappers and other user aliases.
  [[ -s "$HOME/.bash_aliases" ]] && . "$HOME/.bash_aliases"

  # Navigation aliases.
  alias ..='cd ..'
  alias ...='cd ../..'
  alias ....='cd ../../..'

  # Network & misc utilities.
  alias pubip='dig +short myip.opendns.com @resolver1.opendns.com'
  alias timer='echo "Timer started. Stop with Ctrl-D." && time cat'

  {{ if eq .chezmoi.os "darwin" -}}
  # Register interactive claude sessions with Claude Desktop; global default is off so CodexBar probes don't clutter the Code tab.
  alias claude='/opt/homebrew/bin/claude --remote-control'
  alias ping='ping --apple-time'
  alias bu='brew upgrade --formula'
  alias rm='trash-put'
  {{- end }}

  # Disable flow control. For example, Ctrl+s suspends flow-control, and Ctrl+q resumes flow
  # control. (A detailed explanation can be found at https://stackoverflow.com/questions/791765
  stty -ixon

  # Custom Bash Bindings:
  [[ -s "$HOME/.bash_bindings" ]] && . "$HOME/.bash_bindings"
  [[ -s "$HOME/.fzf_bindings" ]] && . "$HOME/.fzf_bindings"
fi

# Zoxide: https://github.com/ajeetdsouza/zoxide
# ⚠️ Must initialize after all other tools that modify PROMPT_COMMAND (especially starship).
eval "$(zoxide init bash)"

# Atuin: https://atuin.sh/
# SQLite-backed shell history via daemon. atuin init registers its own
# __atuin_preexec/__atuin_precmd with bash-preexec (sourced earlier).
# ⚠️ Must initialize after zoxide (both modify PROMPT_COMMAND; atuin last).
eval "$(atuin init bash --disable-up-arrow)"

# ┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓
# ┃  Atuin daemon drift self-heal                  ┃
# ┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛
# If /opt/homebrew/bin/atuin is newer than the daemon's PID file, brew
# autoupdate (or `chezmoi apply`) replaced the binary while the daemon kept
# running stale code. Bounce the LaunchAgent in the background. Layered with
# .chezmoiscripts/run_after_45-bounce-atuin-daemon-on-upgrade.sh.tmpl, which
# uses version-string comparison at chezmoi-apply time.
{{ if eq .chezmoi.os "darwin" -}}
if [[ -f $HOME/.local/share/atuin/atuin-daemon.pid && /opt/homebrew/bin/atuin -nt $HOME/.local/share/atuin/atuin-daemon.pid ]]; then
  launchctl kickstart -k "gui/$(id -u)/com.webdavis.atuin-daemon" >/dev/null 2>&1 &
fi
{{- end }}

# ┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓
# ┃  Long-running command notifier (v2 §7.1)      ┃
# ┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛
# Uses bash-preexec (sourced via Homebrew earlier) instead of a naked DEBUG
# trap, which would clobber atuin's recording.
__cmd_notify_start=""
__cmd_notify_name=""

__cmd_notify_preexec() {
  __cmd_notify_start=$SECONDS
  __cmd_notify_name="$1"
}

__cmd_notify_precmd() {
  local exit_code=$?
  [[ -z $__cmd_notify_start ]] && return
  local elapsed=$((SECONDS - __cmd_notify_start))
  __cmd_notify_start=""
  # Skip known interactive TUIs.
  [[ $__cmd_notify_name =~ ^(vim|nvim|less|man|top|btop|ssh|herdr|claude|hermes|codex|fzf) ]] && return
  # Wrap each background call in a subshell so jobs aren't attached to this
  # interactive shell (otherwise `fg`/`jobs` would grab them).
  if ((elapsed >= 300)); then
    (alerter --timeout 10 --title "Command finished" --message "${__cmd_notify_name%% *} (${elapsed}s)" --sound default >/dev/null 2>&1 &)
    ("$HOME/.local/bin/hue-pulse.sh" "$exit_code" >/dev/null 2>&1 &)
  elif ((elapsed >= 30)); then
    (alerter --timeout 10 --title "Command finished" --message "${__cmd_notify_name%% *} (${elapsed}s)" --sound default >/dev/null 2>&1 &)
  fi
}

# shellcheck disable=SC2034  # preexec_functions/precmd_functions consumed by bash-preexec
preexec_functions+=(__cmd_notify_preexec)
# shellcheck disable=SC2034
precmd_functions+=(__cmd_notify_precmd)

# Order matters! These local (user-level) tools should always take precedence in my environment.
path_prepend "$HOME/.local/bin"
path_prepend "$HOME/.bun/bin"

# ⚠️ Keep this as the last line. Writes the updated PATH to the Bash `env`.
export PATH

# ┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓
# ┃         Herdr: Auto-attach Session       ┃
# ┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛

case $- in
  *i*) ;;      # interactive terminal session, continue
  *) return ;; # non-interactive terminal session, exit
esac

# Skip if herdr isn't installed or already in a pane.
command -v herdr &>/dev/null || return
[[ -n ${HERDR_ENV:-} ]] && return

# Do not interfere with non-interactive remote commands (ssh host 'cmd').
[[ -n ${SSH_ORIGINAL_COMMAND:-} ]] && return

# Skip herdr for VS Code Remote SSH connections.
[[ -n ${VSCODE_INJECTION:-} ]] && return

# Skip herdr for VS Code integrated terminals.
[[ ${TERM_PROGRAM:-} == "vscode" ]] && return

# Launch or attach to the persistent herdr session (starts the server if it
# isn't running). herdr has no launch-into-workspace flag, so this opens the
# last-focused workspace, homelab once you've been there, since the session
# persists. Jump to homelab anytime via prefix+ctrl+h or the `h` alias.
# NOTE: `herdr workspace create` is a socket call that needs a running server
# and does not attach the terminal, do not use it here.
herdr
