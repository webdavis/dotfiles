#!/usr/bin/env bash
set -euo pipefail
printf "%s\n" "Running pre-commit checks..."

# Check-only: linters report drift, never mutate the working tree, never
# touch the index. This preserves partial-commit isolation (`git commit -p`)
# and keeps cosmetic formatter edits as deliberate, separate commits.
if ! just lint-check; then
  printf "\n%s\n" "❌ Pre-commit checks failed!"
  printf "%s\n" "Run 'just l' to auto-fix, review the changes, stage what you want, and re-commit."
  printf "%s\n" "(Or skip with 'git commit --no-verify'.)"
  exit 1
fi

printf "%s\n" "✅ All pre-commit checks passed!"
