#!/usr/bin/env bash
set -euo pipefail
printf "%s\n" "Running pre-commit checks..."

# COMMIT GATE = unit tests + secret scan ONLY (test pyramid, operator
# 2026-07-11). The commit-to-commit loop must stay fast: format drift, the
# integration and e2e camps, and the full flake check all moved to the
# pre-push hook (.githooks/pre-push) and CI, where their latency belongs.
# A commit can therefore carry format drift or an integration regression for
# a few minutes; push and CI still block anything broken from reaching main.
if ! just test-unit; then
  printf "\n%s\n" "❌ Unit tests failed!"
  printf "%s\n" "Fix the failing test(s) above (or skip with 'git commit --no-verify')."
  exit 1
fi

# Secret scan: block any staged plaintext secret. --redact so a hit never
# prints the secret to the terminal. gitleaks is provisioned as a Homebrew
# formula (declared in .chezmoidata/system_packages_autoinstall.yaml).
if command -v gitleaks >/dev/null 2>&1; then
  if ! gitleaks git --staged --no-banner --redact; then
    printf "\n%s\n" "❌ gitleaks found a staged secret. Remove it (or allowlist a false positive) and re-commit."
    exit 1
  fi
fi

printf "%s\n" "✅ All pre-commit checks passed!"
