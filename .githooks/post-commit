#!/usr/bin/env bash
# Project-level graphify rebuild for this repo, run by the user-wide
# post-commit dispatcher (dot_config/git/hooks/executable_post-commit).
#
# Rebuilds graphify-out/graph.json (the committed knowledge-graph map) after
# each commit via the supported CLI (`graphify update .`), DETACHED so the
# commit returns immediately (a full rebuild of this repo measures ~2s; the
# detach keeps even a slow future rebuild off the commit path). Output goes to
# ~/.local/log/graphify/dotfiles-post-commit.log. The rebuilt map shows up as
# an unstaged graphify-out/graph.json change to fold into the next commit
# (deterministic: PYTHONHASHSEED is pinned, so a no-change rebuild rewrites an
# identical file).
#
# A post-commit hook must never surface as a commit failure: every path here
# exits 0. Per-commit escape hatch: GRAPHIFY_SKIP_HOOK=1.
set -euo pipefail

[[ ${GRAPHIFY_SKIP_HOOK:-0} == 1 ]] && exit 0

# No launcher, no rebuild (fresh machine before the uv tool install lands).
command -v graphify >/dev/null 2>&1 || exit 0

# Skip during rebase/merge/cherry-pick so a rebuilt map never blocks
# --continue with unstaged changes.
git_dir=${GIT_DIR:-$(git rev-parse --git-dir 2>/dev/null)} || exit 0
[[ -d "$git_dir/rebase-merge" ]] && exit 0
[[ -d "$git_dir/rebase-apply" ]] && exit 0
[[ -f "$git_dir/MERGE_HEAD" ]] && exit 0
[[ -f "$git_dir/CHERRY_PICK_HEAD" ]] && exit 0

# Skip when the commit only touched graphify-out/ (a map-only commit changes
# no code, so the graph cannot change; this also prevents rebuild loops).
changed="$(git diff --name-only HEAD~1 HEAD 2>/dev/null || git diff --name-only HEAD 2>/dev/null)" || true
[[ -n $changed ]] || exit 0
non_graph="$(printf '%s\n' "$changed" | grep -v '^graphify-out/' || true)"
[[ -n $non_graph ]] || exit 0

log_dir="${HOME}/.local/log/graphify"
mkdir -p "$log_dir" 2>/dev/null || exit 0
# Deterministic clustering: louvain community assignment order depends on
# PYTHONHASHSEED; pinning it keeps the committed graph.json reproducible.
(PYTHONHASHSEED=0 graphify update . >>"$log_dir/dotfiles-post-commit.log" 2>&1 &)
exit 0
